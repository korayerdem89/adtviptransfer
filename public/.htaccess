<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let direct file and directory requests pass through.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # SPA fallback for client-side routes.
  RewriteRule . /index.html [L]
</IfModule>
